GEMINI_API_KEY=AIzaSyDx8LCyxFkkGtO0LG95S4Apy-j0iGu_PbM
GOOGLE_API_KEY=AIzaSyDx8LCyxFkkGtO0LG95S4Apy-j0iGu_PbM
# Either model can be used by the Gemini route; the app prefers GEMINI_MODEL and falls back to GEMINI_FALLBACK_MODEL.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
# Optional fallback provider if Gemini fails.
GROQ_API_KEY=your_groq_api_key_here
# Example Groq model names: llama-3.1-8b-instant or llama-3.1-70b-versatile.
GROQ_MODEL=llama-3.1-8b-instant
# Set to 1 to force the TTS route to use a local generated WAV instead of calling Google TTS.
DEV_TTS_FAKE=1
